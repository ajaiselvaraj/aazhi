# ═══════════════════════════════════════════════════════════
# AAZHI Frontend — Environment Variables
# Copy this file to .env and adjust values as needed.
# ═══════════════════════════════════════════════════════════

# Backend API base URL
VITE_API_URL=http://localhost:5000/api

# Maximum API calls allowed per rolling 60-second window
VITE_MAX_API_CALLS_PER_MINUTE=30

# Maximum concurrent in-flight requests at any time
VITE_MAX_CONCURRENT_REQUESTS=2

# Maximum retry attempts on HTTP 429 / RESOURCE_EXHAUSTED
VITE_API_RETRY_MAX=5

# Gemini AI API Key
VITE_GEMINI_API_KEY=your_gemini_api_key_here
