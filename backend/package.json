{
  "name": "suvidha-backend",
  "version": "1.0.0",
  "description": "Unified Civic Utility Self-Service KIOSK Platform Backend",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "cross-env NODE_ENV=production node server.js",
    "dev": "nodemon server.js",
    "fresh": "taskkill /F /IM node.exe & npm run dev",
    "db:init": "node models/migrate.js",
    "db:ping": "node -e \"import('./config/db.js').then(m => m.testConnection(3, 1000)).then(ok => process.exit(ok ? 0 : 1))\"",
    "test": "jest"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.3",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-openid-connect": "^2.19.4",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "joi": "^17.10.0",
    "jsonwebtoken": "^9.0.0",
    "morgan": "^1.10.0",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "nodeman": "^1.1.2",
    "otp-generator": "^4.0.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.11.0",
    "razorpay": "^2.9.0",
    "twilio": "^5.13.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
